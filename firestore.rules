rules_version = '2';
/* ============================================================
   GR دوام الموظفين — Firestore Security Rules
   Multi-Tenant Architecture with Row-Level Security

   TENANT ISOLATION MODEL:
   - Each shop = one tenant (tenantId === shopId)
   - All documents carry tenantId for row-level enforcement
   - Employee Portal: reads own record only via token lookup
   - Shop Manager: reads/writes only within own tenantId
   - Super Admin: all access (enforced at UI level, same anon auth)
   - employees_by_token: public readable by token (needed for
     employee.html to resolve token → employeeId without knowing shopId)

   SECURITY NOTE (same as existing architecture):
   All clients use anonymous auth — we cannot cryptographically
   distinguish admin from manager from employee at the Rules layer.
   Tenant isolation is enforced via tenantId field checks.
   Password verification and role gating happen in app code.
   ============================================================ */

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }
    function tenantMatches(tenantId) {
      return request.auth != null && resource.data.tenantId == tenantId;
    }

    /* ── shops (top-level tenant registry) ──────────────────── */
    match /shops/{shopId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.keys().hasAll(['name','username'])
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0;
      allow update: if isSignedIn();
      allow delete: if false;

      /* ── employees (per-tenant sub-collection) ────────────── */
      match /employees/{employeeId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn()
          && request.resource.data.keys().hasAll(['name','shopId','tenantId'])
          && request.resource.data.keys().hasAny(['token','username'])
          && request.resource.data.tenantId == shopId;
        allow update: if isSignedIn();
        allow delete: if isSignedIn();
      }
    }

    /* ── employees_by_token (root-level token index) ─────────
       Allows employee.html to resolve token → employeeId
       without knowing shopId in advance. Only token holder
       can effectively use this (they supply the token in URL).
       Write-protected: only the creating client can set it,
       and reads are open to any signed-in user (the token
       itself is the secret — 128-bit random hex).
       ──────────────────────────────────────────────────────── */
    match /employees_by_token/{token} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn()
        && request.resource.data.keys().hasAll(['token','employeeId','shopId','tenantId']);
      allow delete: if isSignedIn();
    }

    /* ── attendance day-documents ────────────────────────────── */
    match /attendance/{attendanceId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if false;

      /* ── per-employee per-day records (collection-group rule) ─
         Written as top-level /{path=**}/records/{employeeId}
         to ensure collectionGroup() queries are covered
         unambiguously (Firestore Rules requirement for
         collection-group query security).
         ──────────────────────────────────────────────────────── */
    }

    /* Collection-group rule for "records" subcollection.
       Must be top-level (/{path=**}/...) not nested, per Firestore docs. */
    match /{path=**}/records/{employeeId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn();
      allow delete: if false;
    }

    /* ── correction_requests ─────────────────────────────────── */
    match /correction_requests/{requestId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.keys().hasAll(['employeeId','shopId','tenantId','date','reason','status'])
        && request.resource.data.status == 'pending';
      allow update: if isSignedIn();
      allow delete: if false;
    }

    /* ── gate accounts (10 fixed system-wide login accounts) ─── */
    match /gate_accounts/{username} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.keys().hasAll(['username','passwordHash','passwordSalt','passwordIterations']);
      allow update: if isSignedIn();
      allow delete: if false;
    }

    /* ── gate sessions (single-device-per-account lock) ──────── */
    match /gate_sessions/{username} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    /* ── payroll deductions ──────────────────────────────────── */
    match /payroll_deductions/{docId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    /* ── audit logs (append-only) ────────────────────────────── */
    match /audit_logs/{logId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.keys().hasAll(['action','timestamp']);
      allow update, delete: if false;
    }

    /* ── system config (admin password hash) ─────────────────── */
    match /system_config/{configId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    /* ── default deny ────────────────────────────────────────── */
    match /{document=**} {
      allow read, write: if false;
    }
  }
}